# ── Banco de Dados ──
POSTGRES_DB=crm_sitio
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_secret
DATABASE_URL=postgresql://crm:crm_secret@db:5432/crm_sitio

# ── Redis / Celery ──
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Criptografia ──
AES_SECRET_KEY=trocar-por-chave-segura-de-32-bytes

# ── WhatsApp (Evolution API) ──
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=sitio-dom-pedro

# ── WhatsApp (Z-API) — alternativa ──
# WHATSAPP_PROVIDER=zapi
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_SECURITY_TOKEN=

# ── Pagamentos (Asaas) ──
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox

# ── Contratos (ZapSign) ──
ZAPSIGN_API_TOKEN=

# ── Email (SendGrid) ──
SENDGRID_API_KEY=
EMAIL_FROM=contato@sitiodomPedro.com.br

# ── Email SMTP fallback (alternativa ao SendGrid) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seuemail@gmail.com
# SMTP_PASSWORD=

# ── Google Calendar (Service Account) ──
# Cole o conteúdo JSON do Service Account ou informe o path do arquivo
GOOGLE_CALENDAR_CREDENTIALS_JSON=
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_AUTO_SYNC=true
GOOGLE_CALENDAR_INVITE_LEAD=false

# ── IA (OpenAI) — opcional ──
OPENAI_API_KEY=
